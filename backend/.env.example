# ----- Database (Neon) -----
# Copy the connection string from your Neon dashboard. Example:
#   jdbc:postgresql://ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/post
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=1234
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT (generate a long random secret, min 32 bytes) -----
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes-long
JWT_ACCESS_EXPIRATION=600000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=instagram-analytics
JWT_AUDIENCE=instagram-analytics-client

# ----- Credential encryption (AES-256) -----
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=

# ----- OAuth2 (Google) -----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- CORS / WebSocket -----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Server -----
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ----- Frontend (Vite) -----
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws
